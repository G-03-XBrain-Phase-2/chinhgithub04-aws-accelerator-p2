# Vùng AWS triển khai tài nguyên
aws_region = "us-east-1"

# Loại máy ảo EC2 dùng làm Host chạy cụm Kind (khuyến nghị tối thiểu t3.medium)
instance_type = "t3.micro"

# Tên của dự án/lab
project_name = "w8-k8s-lab"

# Các thẻ tag chung để gắn lên tài nguyên AWS
tags = {
  Environment = "lab"
  Owner       = "XB-DN26-080"
  Project     = "W8-K8s-ALB-Automation"
  ManagedBy   = "Terraform"
}
